        <class>vn.iotstar.entity.CourseType</class>
        <class>vn.iotstar.entity.Discount</class>
        <class>vn.iotstar.entity.Discussion</class>
        <class>vn.iotstar.entity.FavoriteCourse</class>
        <class>vn.iotstar.entity.Lesson</class>
        <class>vn.iotstar.entity.LessonProgress</class>
        <class>vn.iotstar.entity.Notification</class>
        <class>vn.iotstar.entity.OrderItem</class>
        <class>vn.iotstar.entity.Orders</class>
        <class>vn.iotstar.entity.Payment</class>
        <class>vn.iotstar.entity.Question</class>
        <class>vn.iotstar.entity.Quiz</class>
        <class>vn.iotstar.entity.Review</class>
        <class>vn.iotstar.entity.Role</class>
